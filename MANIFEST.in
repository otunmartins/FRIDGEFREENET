# Include the README
include README.md

# Include license
include LICENSE

# Include requirements files
include pyproject.toml

# Include configuration files
recursive-include src/insulin_ai/config *.yaml *.yml *.json *.toml

# Include data files
recursive-include src/insulin_ai/data *.json *.yaml *.yml *.csv *.txt

# Include templates and static files
recursive-include src/insulin_ai/templates *.html *.jinja2 *.j2
recursive-include src/insulin_ai/static *.css *.js *.png *.jpg *.jpeg *.gif *.svg *.ico

# Include documentation
recursive-include docs *.md *.rst *.txt *.png *.jpg *.jpeg *.gif *.svg

# Exclude test files and temporary directories
recursive-exclude * __pycache__
recursive-exclude * *.py[co]
recursive-exclude * *.pdb
recursive-exclude * *.dcd
recursive-exclude * *.log
recursive-exclude * *_temp
recursive-exclude * test_*
recursive-exclude * *_test
recursive-exclude * preprocessed_*
recursive-exclude * enhanced_polymer_*
recursive-exclude * automated_simulations
recursive-exclude * simple_md_simulations
recursive-exclude * enhanced_md_simulations

# Exclude backup files
recursive-exclude * *.bak
recursive-exclude * *.backup
recursive-exclude * *~

# Exclude IDE files
recursive-exclude * .vscode
recursive-exclude * .idea
recursive-exclude * *.swp
recursive-exclude * *.swo

# Exclude environment files
recursive-exclude * .env
recursive-exclude * *.key
recursive-exclude * secrets.toml 