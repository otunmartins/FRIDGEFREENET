{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "materials-discovery",
  "experimental": {
    "mcp_timeout": 2147483647
  },
  "mcp": {
    "insulin-ai": {
      "type": "local",
      "command": ["bash", "scripts/run_mcp_server.sh"],
      "environment": {
        "PAPER_DIRECTORY": "./papers"
      },
      "enabled": true
    }
  }
}
