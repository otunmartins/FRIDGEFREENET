# Environment Variables Template for Insulin-AI Vast.ai Deployment
# Copy this file to .env and fill in your actual values

# =============================================================================
# API KEYS - REQUIRED
# =============================================================================

# OpenAI API Key (required for LLM operations)
OPENAI_API_KEY=your_openai_api_key_here

# LangChain API Key (optional - for LangSmith tracing)
LANGCHAIN_API_KEY=your_langchain_api_key_here

# Vast.ai API Key (optional - for CLI operations)
VAST_API_KEY=your_vast_api_key_here

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Environment setting
NODE_ENV=production

# Streamlit configuration
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_SERVER_HEADLESS=true

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# =============================================================================
# MOLECULAR DYNAMICS CONFIGURATION
# =============================================================================

# OpenMM Platform preference (CUDA, OpenCL, CPU)
OPENMM_DEFAULT_PLATFORM=CUDA

# CUDA device to use (0, 1, 2, etc. or "all")
CUDA_VISIBLE_DEVICES=0

# Default simulation parameters
DEFAULT_TEMPERATURE=310.0
DEFAULT_EQUILIBRATION_STEPS=125000
DEFAULT_PRODUCTION_STEPS=500000
DEFAULT_SAVE_INTERVAL=1000

# =============================================================================
# LITERATURE MINING CONFIGURATION
# =============================================================================

# Default search parameters
LITERATURE_MAX_PAPERS=10
LITERATURE_STRATEGY=Comprehensive
LITERATURE_RECENT_ONLY=true
LITERATURE_INCLUDE_PATENTS=false

# Model configuration
LITERATURE_MODEL=gpt-4o-mini
LITERATURE_TEMPERATURE=0.7
LITERATURE_MAX_TOKENS=3000

# =============================================================================
# PSMILES GENERATION CONFIGURATION  
# =============================================================================

# Generation parameters
PSMILES_MAX_RETRIES=5
PSMILES_NUM_CANDIDATES=1
PSMILES_ENABLE_FUNCTIONALIZATION=true
PSMILES_MAX_REPAIR_ATTEMPTS=3
PSMILES_TEMPERATURE=0.7

# =============================================================================
# ACTIVE LEARNING CONFIGURATION
# =============================================================================

# Orchestrator settings
ACTIVE_LEARNING_MAX_ITERATIONS=5
ACTIVE_LEARNING_TIMEOUT_MINUTES=30
ACTIVE_LEARNING_MAX_SIMULATIONS=3

# Performance thresholds
BIOCOMPATIBILITY_TARGET=0.90
STABILITY_TARGET=0.80
DEGRADATION_RATE_TARGET=0.50

# =============================================================================
# VAST.AI SPECIFIC SETTINGS
# =============================================================================

# Instance configuration
VAST_INSTANCE_TYPE=RTX4090
VAST_MIN_GPU_RAM=24000
VAST_MIN_RAM=32000
VAST_MIN_DISK_SPACE=100
VAST_MIN_CUDA_VERSION=11.8

# Network configuration
VAST_OPEN_BUTTON_PORT=8501
VAST_JUPYTER_PORT=8888
VAST_SSH_PORT=22

# =============================================================================
# MONITORING AND ALERTING
# =============================================================================

# Health check configuration
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10
HEALTH_CHECK_RETRIES=3

# Performance monitoring
MONITOR_GPU_USAGE=true
MONITOR_MEMORY_USAGE=true
MONITOR_SIMULATION_PERFORMANCE=true 